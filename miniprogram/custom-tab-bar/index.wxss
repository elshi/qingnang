.tab-bar {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 99;
  display: flex;
  height: calc(125rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  border-top: 1rpx solid #e8e2d9;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -4rpx 18rpx rgba(47, 36, 25, 0.035);
}

.tab-item {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: flex-start;
  height: 125rpx;
  padding-top: 21rpx;
  color: #5c5c5a;
  text-decoration: none;
}

.tab-icon {
  display: block;
  flex: 0 0 46rpx;
  width: 46rpx;
  height: 46rpx;
}

.tab-label {
  flex: 0 0 auto;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1;
}

.tab-item--active {
  color: #b57923;
}

.tab-item--pressed {
  opacity: 0.78;
}
