@import "./styles/design-token.wxss";

page {
  min-height: 100%;
  color: #2F2419;
  background-color: #F7F2EA;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

view,
text,
image,
input,
button,
 navigator,
scroll-view {
  box-sizing: border-box;
}

button {
  padding: 0;
  border: 0;
  background: transparent;
  line-height: normal;
}

button::after {
  border: 0;
}

.page-shell {
  position: relative;
  min-height: 100vh;
  padding: 0 32rpx 158rpx;
  overflow: hidden;
  background-color: #F7F2EA;
  background-image: url("/assets/common/paper-bg.png");
  background-position: top center;
  background-repeat: repeat-y;
  background-size: 750rpx auto;
}

.paper-card {
  border: 1rpx solid #E9DED0;
  border-radius: 24rpx;
  background: #FCFAF5;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}

.pressable {
  transition: transform 300ms ease, opacity 300ms ease;
}

.pressable:active {
  opacity: 0.92;
  transform: scale(0.98);
}

.page-fade {
  animation: page-fade-in 300ms ease both;
}

@keyframes page-fade-in {
  from { opacity: 0; }
  to { opacity: 1; }
}

