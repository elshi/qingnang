.classic-page { display:flex; flex-direction:column; height:100vh; overflow:hidden; background:#f8f3ea url("/assets/common/paper-bg.png") top center/750rpx auto repeat-y; }
.search-wrap { flex:0 0 auto; padding:12rpx 34rpx 18rpx; border-bottom:1rpx solid rgba(224,213,196,.55); }
.search-box { display:flex; align-items:center; height:72rpx; padding:0 22rpx; border:1rpx solid rgba(225,214,198,.8); border-radius:29rpx; background:rgba(255,253,248,.68); }
.search-box image { flex:0 0 31rpx; width:31rpx; height:31rpx; opacity:.62; }
.search-box input { flex:1; height:72rpx; margin-left:18rpx; color:#40372d; font-size:23rpx; }
.search-placeholder { color:#a0968b; }
.clear-button { color:#aa762f; font-size:20rpx; }
.content-scroll { flex:1; min-height:0; }
.section-head { display:flex; align-items:center; height:73rpx; padding:0 32rpx; color:#372c21; font-size:27rpx; font-weight:600; }
.flame-mark { width:15rpx; height:22rpx; margin-right:13rpx; border-radius:50% 50% 52% 12%; background:#bd7c25; transform:rotate(45deg); }
.result-count { margin-left:auto; color:#a0988e; font-size:19rpx; font-weight:400; }
.formula-list { padding:0 25rpx 24rpx; }
.formula-card { position:relative; display:flex; min-height:183rpx; margin-bottom:15rpx; padding:15rpx; border:1rpx solid rgba(229,218,202,.78); border-radius:14rpx; background:rgba(255,253,248,.78); box-shadow:0 4rpx 13rpx rgba(73,51,27,.04); }
.formula-image-wrap { display:flex; align-items:center; justify-content:center; flex:0 0 142rpx; width:142rpx; height:151rpx; overflow:hidden; border-radius:10rpx; background:#f7ecdc; }
.formula-image { width:142rpx; height:151rpx; filter:saturate(.72); }
.formula-copy { flex:1; min-width:0; margin-left:23rpx; padding-bottom:34rpx; }
.formula-title-line { display:flex; align-items:center; flex-wrap:wrap; gap:7rpx; min-height:38rpx; }
.formula-title { margin-right:5rpx; color:#30271e; font-size:28rpx; font-weight:600; }
.soft-tag { padding:2rpx 9rpx; border-radius:5rpx; color:#9b6b28; background:#f3e9da; font-size:18rpx; line-height:29rpx; }
.formula-source { color:#91887e; font-size:18rpx; }
.formula-summary { margin-top:14rpx; color:#655d53; font-size:21rpx; line-height:1.55; }
.formula-meta { position:absolute; bottom:17rpx; left:180rpx; color:#978c80; font-size:18rpx; }
.outline-action { position:absolute; right:14rpx; bottom:12rpx; min-width:66rpx; padding:3rpx 11rpx; border:1rpx solid #c9964d; border-radius:18rpx; color:#a66e24; font-size:17rpx; line-height:28rpx; text-align:center; }
.empty-state { padding:170rpx 20rpx; text-align:center; }
.empty-title,.empty-copy { display:block; }
.empty-title { color:#46392c; font-size:28rpx; }
.empty-copy { margin-top:13rpx; color:#9a8f83; font-size:21rpx; }
.reset-button { width:150rpx; height:55rpx; margin:28rpx auto 0; border:1rpx solid #c9964d; border-radius:28rpx; color:#a66e24; font-size:21rpx; line-height:55rpx; }
.bottom-spacer { height:calc(125rpx + env(safe-area-inset-bottom)); }
