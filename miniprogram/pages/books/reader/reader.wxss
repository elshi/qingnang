.reader-page { display:flex; flex-direction:column; width:100%; height:100vh; overflow:hidden; background:#f8f3ea url("/assets/common/paper-bg.png") top center/750rpx auto repeat-y; }
.reader-scroll { flex:1; min-height:0; width:100%; }
.reader-hero,.chapter-directory,.chapter-card { margin-right:26rpx; margin-left:26rpx; border:1rpx solid rgba(225,214,198,.9); border-radius:12rpx; background:rgba(255,253,248,.84); }
.reader-hero { margin-top:28rpx; padding:32rpx 28rpx; }
.reader-book-name { color:#31291f; font-size:38rpx; font-weight:600; line-height:1.4; }
.reader-meta { margin-top:9rpx; color:#9b7241; font-size:21rpx; line-height:1.5; }
.reader-summary { margin-top:20rpx; color:#655d53; font-size:23rpx; line-height:1.75; }
.chapter-directory { margin-top:20rpx; padding:23rpx 0 20rpx; }
.section-title { padding:0 24rpx; color:#65451f; font-size:27rpx; font-weight:600; }
.chapter-scroll { width:100%; margin-top:16rpx; white-space:nowrap; }
.chapter-row { display:inline-flex; gap:12rpx; padding:0 24rpx; }
.chapter-tab { flex:0 0 auto; max-width:320rpx; height:58rpx; margin:0; padding:0 20rpx; overflow:hidden; border:1rpx solid rgba(201,155,86,.65); border-radius:29rpx; color:#87612b; background:#f7efe2; font-size:20rpx; line-height:56rpx; text-overflow:ellipsis; white-space:nowrap; }
.chapter-tab::after { border:0; }
.chapter-tab--active { color:#fff8eb; background:#b77a2c; }
.chapter-card { margin-top:20rpx; margin-bottom:20rpx; padding:30rpx 28rpx; }
.chapter-title { margin-bottom:23rpx; color:#65451f; font-size:32rpx; font-weight:600; line-height:1.5; text-align:center; }
.chapter-line { color:#51483e; font-size:29rpx; line-height:2; white-space:pre-wrap; }
.chapter-line--empty { height:20rpx; line-height:20rpx; }
.reader-state { padding-top:220rpx; color:#81776b; font-size:24rpx; text-align:center; }
.reader-state--chapter { padding:80rpx 20rpx; }
.reader-retry { display:inline-block; margin-top:24rpx; padding:10rpx 28rpx; border:1rpx solid #c99b56; border-radius:30rpx; color:#a8752c; font-size:21rpx; }
.disclaimer { padding:22rpx 38rpx 70rpx; color:#9e9489; font-size:19rpx; line-height:1.7; text-align:center; }
