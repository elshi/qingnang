.reader-page {
  --reader-bg: #f4eddf;
  --reader-text: #443a2f;
  --reader-muted: #927f66;
  --reader-panel: rgba(250, 246, 238, 0.98);
  --reader-border: rgba(134, 105, 70, 0.22);
  --reader-accent: #a66d25;
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  color: var(--reader-text);
  background: var(--reader-bg);
}

.reader-page--eye {
  --reader-bg: #dfe8d2;
  --reader-text: #34402f;
  --reader-muted: #74806c;
  --reader-panel: rgba(234, 240, 225, 0.98);
  --reader-border: rgba(74, 96, 66, 0.2);
  --reader-accent: #617c52;
}

.reader-page--night {
  --reader-bg: #1e211f;
  --reader-text: #c5c2b8;
  --reader-muted: #8f938b;
  --reader-panel: rgba(38, 42, 39, 0.99);
  --reader-border: rgba(210, 214, 205, 0.14);
  --reader-accent: #b99a6a;
}

.reader-scroll {
  width: 100%;
  height: 100%;
  background: var(--reader-bg);
}

.chapter-content {
  min-height: 100vh;
  padding: 150rpx 48rpx 220rpx;
  color: var(--reader-text);
  background-image: linear-gradient(rgba(255, 255, 255, 0.035), rgba(255, 255, 255, 0.035));
  letter-spacing: 1rpx;
  text-align: justify;
}

.reader-page--night .chapter-content {
  background-image: none;
}

.chapter-title {
  margin: 31rpx 12rpx 60rpx;
  color: var(--reader-text);
  font-family: "KaiTi", "STKaiti", serif;
  font-size: 1.25em;
  font-weight: 700;
  line-height: 1.55;
  text-align: center;
}

.chapter-paragraph {
  margin-bottom: 1.15em;
  text-indent: 2em;
  white-space: pre-wrap;
}

.chapter-end {
  margin-top: 80rpx;
  color: var(--reader-muted);
  font-size: 22rpx;
  letter-spacing: 6rpx;
  text-align: center;
}

.reader-state {
  padding: 300rpx 30rpx 80rpx;
  color: var(--reader-muted);
  font-size: 24rpx;
  text-align: center;
}

.reader-retry {
  display: inline-block;
  margin-top: 24rpx;
  padding: 10rpx 28rpx;
  border: 1rpx solid var(--reader-accent);
  border-radius: 30rpx;
  color: var(--reader-accent);
  font-size: 21rpx;
}

.chapter-loading,
.chapter-error {
  position: fixed;
  z-index: 25;
  top: 50%;
  left: 50%;
  padding: 18rpx 28rpx;
  border: 1rpx solid var(--reader-border);
  border-radius: 10rpx;
  color: var(--reader-text);
  background: var(--reader-panel);
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.12);
  font-size: 22rpx;
  transform: translate(-50%, -50%);
}

.chapter-error {
  display: flex;
  align-items: center;
  width: 520rpx;
  justify-content: space-between;
}

.chapter-error__retry {
  flex: 0 0 auto;
  margin-left: 20rpx;
  color: var(--reader-accent);
  font-size: 22rpx;
}

.reader-topbar,
.reader-bottombar {
  position: fixed;
  z-index: 20;
  right: 0;
  left: 0;
  color: var(--reader-text);
  background: var(--reader-panel);
  box-shadow: 0 3rpx 18rpx rgba(0, 0, 0, 0.08);
  opacity: 0;
  pointer-events: none;
  transition: opacity 180ms ease, transform 180ms ease;
}

.reader-topbar {
  top: 0;
  border-bottom: 1rpx solid var(--reader-border);
  transform: translateY(-100%);
}

.reader-bottombar {
  bottom: 0;
  display: flex;
  height: calc(116rpx + env(safe-area-inset-bottom));
  padding: 8rpx 20rpx env(safe-area-inset-bottom);
  border-top: 1rpx solid var(--reader-border);
  transform: translateY(100%);
}

.reader-toolbar--visible {
  opacity: 1;
  pointer-events: auto;
  transform: translateY(0);
}

.reader-topbar__bar {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
}

.reader-back {
  position: absolute;
  z-index: 1;
  top: 50%;
  left: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  transform: translateY(-50%);
}

.reader-back__arrow {
  width: 22rpx;
  height: 22rpx;
  border-bottom: 4rpx solid var(--reader-text);
  border-left: 4rpx solid var(--reader-text);
  transform: rotate(45deg);
}

.reader-back.pressable:active {
  transform: translateY(-50%) scale(0.98);
}

.reader-heading {
  width: 100%;
  padding: 0 184rpx;
  overflow: hidden;
  text-align: center;
}

.reader-heading__book,
.reader-heading__chapter {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.reader-heading__book {
  color: var(--reader-text);
  font-size: 25rpx;
  font-weight: 600;
}

.reader-heading__chapter {
  margin-top: 4rpx;
  color: var(--reader-muted);
  font-size: 18rpx;
}

.reader-tool {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  flex-direction: column;
  color: var(--reader-text);
  font-size: 19rpx;
}

.reader-tool__icon {
  height: 46rpx;
  color: var(--reader-accent);
  font-size: 31rpx;
  line-height: 42rpx;
}

.reader-tool--disabled {
  opacity: 0.32;
}

.reader-mask {
  position: fixed;
  z-index: 29;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(0, 0, 0, 0.38);
}

.directory-drawer {
  position: fixed;
  z-index: 30;
  top: 0;
  bottom: 0;
  left: 0;
  display: flex;
  flex-direction: column;
  width: 610rpx;
  color: var(--reader-text);
  background: var(--reader-panel);
  box-shadow: 10rpx 0 36rpx rgba(0, 0, 0, 0.16);
  transform: translateX(-105%);
  transition: transform 220ms ease;
}

.directory-drawer--visible {
  transform: translateX(0);
}

.panel-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex: 0 0 auto;
  min-height: 118rpx;
  padding: 20rpx 26rpx;
  border-bottom: 1rpx solid var(--reader-border);
}

.panel-title {
  color: var(--reader-text);
  font-size: 29rpx;
  font-weight: 600;
}

.panel-subtitle {
  max-width: 470rpx;
  margin-top: 7rpx;
  overflow: hidden;
  color: var(--reader-muted);
  font-size: 19rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.panel-close {
  flex: 0 0 64rpx;
  width: 64rpx;
  height: 64rpx;
  color: var(--reader-muted);
  font-size: 42rpx;
  line-height: 64rpx;
  text-align: center;
}

.directory-list {
  flex: 1;
  min-height: 0;
}

.directory-item {
  display: flex;
  align-items: flex-start;
  width: 100%;
  min-height: 82rpx;
  padding: 20rpx 20rpx;
  border-bottom: 1rpx solid var(--reader-border);
  color: var(--reader-text);
  font-size: 25rpx;
  line-height: 1.6;
  text-align: left;
}

.directory-item--active {
  color: var(--reader-accent);
  background: rgba(166, 109, 37, 0.1);
}

.directory-item__number {
  flex: 0 0 50rpx;
  color: var(--reader-muted);
  font-size: 21rpx;
}

.directory-item--active .directory-item__number {
  color: var(--reader-accent);
}

.directory-item__title {
  flex: 1;
  min-width: 0;
}

.settings-panel {
  position: fixed;
  z-index: 30;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  flex-direction: column;
  max-height: calc(100vh - 32rpx);
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: border-box;
  overflow: hidden;
  color: var(--reader-text);
  background: var(--reader-panel);
  border-radius: 22rpx 22rpx 0 0;
  box-shadow: 0 -10rpx 36rpx rgba(0, 0, 0, 0.14);
  transform: translateY(105%);
  transition: transform 220ms ease;
}

.settings-panel--visible {
  transform: translateY(0);
}

.settings-panel__head {
  flex: 0 0 auto;
  min-height: 92rpx;
}

.settings-panel__body {
  flex: 1;
  min-height: 0;
}

.setting-row {
  display: flex;
  align-items: center;
  min-height: 94rpx;
  padding: 12rpx 28rpx;
  border-bottom: 1rpx solid var(--reader-border);
}

.setting-row:last-child {
  border-bottom: 0;
}

.setting-label {
  flex: 0 0 82rpx;
  color: var(--reader-muted);
  font-size: 22rpx;
}

.setting-options {
  display: flex;
  flex: 1;
  gap: 12rpx;
  min-width: 0;
}

.setting-option {
  flex: 1;
  min-width: 0;
  height: 54rpx;
  border: 1rpx solid var(--reader-border);
  border-radius: 27rpx;
  color: var(--reader-text);
  background: transparent;
  font-size: 20rpx;
  line-height: 52rpx;
  white-space: nowrap;
}

.setting-option--active {
  border-color: var(--reader-accent);
  color: var(--reader-accent);
  font-weight: 600;
}

.theme-option--paper {
  background: #f4eddf;
  color: #443a2f;
}

.theme-option--eye {
  background: #dfe8d2;
  color: #34402f;
}

.theme-option--night {
  background: #1e211f;
  color: #c5c2b8;
}
