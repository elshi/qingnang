<view class="classic-page page-fade">
  <custom-nav title="经典医书" showBack="{{true}}"></custom-nav>
  <view class="book-layout">
    <scroll-view class="dynasty-rail" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view wx:for="{{dynasties}}" wx:key="key" class="dynasty-item pressable {{activeDynasty === item.key ? 'dynasty-item--active' : ''}}" data-key="{{item.key}}" bindtap="selectDynasty">
        <text class="dynasty-label">{{item.label}}</text>
      </view>
      <view class="dynasty-rail-spacer"></view>
    </scroll-view>
    <scroll-view class="book-scroll" scroll-y="{{true}}" enhanced="{{true}}" show-scrollbar="{{false}}">
      <view class="book-list">
        <view wx:for="{{items}}" wx:key="id" wx:for-index="bookIndex" class="book-card pressable" data-id="{{item.id}}" bindtap="openReader">
          <image wx:if="{{!item.coverFailed}}" class="book-cover" src="{{item.cover}}" mode="aspectFill" lazy-load="{{true}}" fade-in="{{true}}" data-index="{{bookIndex}}" binderror="onBookCoverError"></image>
          <view wx:else class="book-cover book-cover--fallback">
            <view class="book-cover__binding"></view>
            <view class="book-cover__frame"><text>{{item.name}}</text></view>
          </view>
          <view class="book-copy">
            <view class="book-title">{{item.name}}</view>
            <view class="book-summary">{{item.summary}}</view>
            <view class="book-meta">{{item.dynasty || '朝代未注明'}} · {{item.author || '作者未注明'}} · {{item.chapter_count}} 章</view>
          </view>
          <view class="outline-action">阅读</view>
        </view>
        <view wx:if="{{loading}}" class="empty-state"><text class="empty-copy">正在加载医书...</text></view>
        <view wx:elif="{{error}}" class="empty-state">
          <text class="empty-copy">{{error}}</text>
          <button class="retry-action pressable" bindtap="retry">重新加载</button>
        </view>
        <view wx:elif="{{!items.length}}" class="empty-state">
          <text class="empty-title">暂无该朝代医书</text>
          <text class="empty-copy">换一个朝代继续研读经典。</text>
        </view>
        <view class="bottom-spacer"></view>
      </view>
    </scroll-view>
  </view>
  <app-tab-bar></app-tab-bar>
</view>
