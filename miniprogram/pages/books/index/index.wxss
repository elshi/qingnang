.classic-page { display:flex; flex-direction:column; height:100vh; overflow:hidden; background:#f8f3ea url("/assets/common/paper-bg.png") top center/750rpx auto repeat-y; }
.book-layout { display:flex; flex:1; min-height:0; margin-bottom:calc(125rpx + env(safe-area-inset-bottom)); border-top:1rpx solid rgba(222,211,194,.55); }
.dynasty-rail { flex:0 0 142rpx; width:142rpx; height:100%; background:rgba(255,252,246,.72); border-right:1rpx solid rgba(230,218,200,.65); }
.dynasty-item { position:relative; display:flex; align-items:center; justify-content:center; width:142rpx; height:88rpx; background:transparent; }
.dynasty-label { position:relative; z-index:2; display:block; color:#4d443a; font-family:"PingFang SC","Microsoft YaHei",sans-serif; font-size:25rpx; font-weight:400; line-height:88rpx; text-align:center; white-space:nowrap; }
.dynasty-item--active { color:#a66b1d; background:rgba(243,226,198,.72); }
.dynasty-item--active .dynasty-label { color:#a66b1d; font-weight:500; }
.dynasty-item--active::before { position:absolute; top:0; bottom:0; left:0; width:5rpx; background:#bd7c25; content:""; }
.dynasty-rail-spacer { height:18rpx; }
.book-scroll { flex:1; min-width:0; height:100%; }
.book-list { padding:18rpx 18rpx 24rpx; }
.book-card { position:relative; display:flex; min-height:202rpx; margin-bottom:15rpx; padding:16rpx 14rpx; border:1rpx solid rgba(229,218,202,.78); border-radius:13rpx; background:rgba(255,253,248,.79); box-shadow:0 4rpx 13rpx rgba(73,51,27,.04); }
.book-cover { flex:0 0 112rpx; width:112rpx; height:166rpx; border-radius:7rpx; filter:saturate(.68); box-shadow:0 4rpx 12rpx rgba(64,43,22,.14); }
.book-copy { flex:1; min-width:0; margin-left:22rpx; padding-bottom:33rpx; }
.book-title { color:#30271e; font-size:28rpx; font-weight:600; line-height:1.35; }
.tag-row { display:flex; flex-wrap:wrap; gap:7rpx; margin-top:10rpx; }
.soft-tag { padding:2rpx 9rpx; border-radius:5rpx; color:#9b6b28; background:#f3e9da; font-size:18rpx; line-height:29rpx; }
.book-summary { margin-top:10rpx; color:#655d53; font-size:20rpx; line-height:1.55; }
.book-meta { position:absolute; right:92rpx; bottom:17rpx; left:148rpx; overflow:hidden; color:#978c80; font-size:18rpx; text-overflow:ellipsis; white-space:nowrap; }
.outline-action { position:absolute; right:13rpx; bottom:12rpx; min-width:65rpx; padding:3rpx 11rpx; border:1rpx solid #c9964d; border-radius:18rpx; color:#a66e24; font-size:17rpx; line-height:28rpx; text-align:center; }
.empty-state { padding:150rpx 10rpx; text-align:center; }
.empty-title,.empty-copy { display:block; }
.empty-title { color:#46392c; font-size:27rpx; }
.empty-copy { margin-top:13rpx; color:#9a8f83; font-size:21rpx; }
.bottom-spacer { height:24rpx; }
