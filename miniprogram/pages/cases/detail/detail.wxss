.detail-page {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100vh;
  overflow: hidden;
  background-color: #f8f3ea;
  background-image: url("/assets/common/paper-bg.png");
  background-position: top center;
  background-repeat: repeat-y;
  background-size: 750rpx auto;
}

.detail-tabs {
  display: flex;
  flex: 0 0 82rpx;
  height: 82rpx;
  padding: 0 150rpx;
  border-bottom: 1rpx solid rgba(214, 202, 185, 0.7);
  background: rgba(247, 242, 234, 0.96);
}

.detail-tab {
  position: relative;
  flex: 1;
  height: 82rpx;
  color: #746b60;
  font-size: 25rpx;
  line-height: 82rpx;
}

.detail-tab--active {
  color: #a87025;
}

.detail-tab--active::after {
  position: absolute;
  right: 50%;
  bottom: -1rpx;
  width: 52rpx;
  height: 3rpx;
  border-radius: 2rpx;
  background: #bd883c;
  transform: translateX(50%);
  content: "";
}

.detail-scroll {
  flex: 1;
  min-height: 0;
  width: 100%;
}

.detail-hero,
.detail-card {
  margin-right: 26rpx;
  margin-bottom: 20rpx;
  margin-left: 26rpx;
  border: 1rpx solid rgba(225, 214, 198, 0.9);
  border-radius: 12rpx;
  background: rgba(255, 253, 248, 0.84);
}

.detail-hero {
  margin-top: 28rpx;
  padding: 34rpx 28rpx;
}

.detail-card--analysis-first {
  margin-top: 28rpx;
}

.detail-title { color: #31291f; font-size: 36rpx; font-weight: 600; line-height: 1.45; }
.detail-meta { margin-top: 16rpx; color: #9b7241; font-size: 21rpx; }
.detail-card { padding: 26rpx 27rpx; }
.detail-card__title { margin-bottom: 17rpx; color: #65451f; font-size: 27rpx; font-weight: 600; }
.detail-page .detail-card__title--original { font-size: 30rpx; }

.detail-content,
.detail-row,
.detail-course {
  color: #5f564c;
  font-size: 23rpx;
  line-height: 1.85;
  white-space: pre-wrap;
}

.detail-row { display: flex; align-items: flex-start; margin-top: 7rpx; }
.detail-label { flex: 0 0 120rpx; color: #9b7241; }
.detail-row__value { flex: 1; min-width: 0; }
.detail-course { margin-top: 12rpx; color: #87612b; }
.detail-page .detail-content.detail-content--original { font-size: 30rpx; }
.prescription-card { border-color: rgba(198, 153, 86, 0.55); }

.learning-note {
  margin-bottom: 17rpx;
  padding: 13rpx 16rpx;
  border-radius: 8rpx;
  color: #91672d;
  background: #f4ead9;
  font-size: 20rpx;
  line-height: 1.6;
}

.prescription-table {
  overflow: hidden;
  border: 1rpx solid rgba(205, 178, 138, 0.65);
  border-radius: 8rpx;
}

.prescription-group + .prescription-group {
  margin-top: 24rpx;
}

.prescription-group__title {
  margin-bottom: 10rpx;
  color: #87612b;
  font-size: 23rpx;
  font-weight: 600;
}

.prescription-table__head,
.prescription-table__row {
  display: flex;
  min-height: 62rpx;
  border-bottom: 1rpx solid rgba(222, 207, 184, 0.7);
  color: #5f564c;
  font-size: 22rpx;
  line-height: 1.6;
}

.prescription-table__head {
  color: #87612b;
  background: #f4ead9;
  font-weight: 600;
}

.prescription-table__row:last-child {
  border-bottom: 0;
}

.prescription-table__name,
.prescription-table__dosage {
  display: flex;
  align-items: center;
  padding: 12rpx 16rpx;
}

.prescription-table__name {
  flex: 1;
  min-width: 0;
}

.prescription-table__dosage {
  flex: 0 0 180rpx;
  border-left: 1rpx solid rgba(222, 207, 184, 0.7);
}

.detail-state {
  padding-top: 220rpx;
  color: #81776b;
  font-size: 24rpx;
  text-align: center;
}

.detail-retry {
  display: inline-block;
  margin-top: 24rpx;
  padding: 10rpx 28rpx;
  border: 1rpx solid #c99b56;
  border-radius: 30rpx;
  color: #a8752c;
  font-size: 21rpx;
}

.tag-row { display: flex; flex-wrap: wrap; gap: 9rpx; margin-top: 18rpx; }
.case-tag { padding: 3rpx 11rpx; border-radius: 4rpx; color: #9b6f2d; background: #f2e8d7; font-size: 19rpx; line-height: 30rpx; }
.symptom-tag-row { display: flex; flex-wrap: wrap; gap: 9rpx; margin-top: 18rpx; }
.symptom-tag { padding: 3rpx 11rpx; border-radius: 4rpx; color: #6e604d; background: #f6efe3; font-size: 20rpx; line-height: 31rpx; }
.disclaimer { padding: 22rpx 38rpx 70rpx; color: #9e9489; font-size: 19rpx; line-height: 1.7; text-align: center; }
