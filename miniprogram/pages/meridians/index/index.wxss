.classic-page { display:flex; flex-direction:column; height:100vh; overflow:hidden; background:#f8f3ea url("/assets/common/paper-bg.png") top center/750rpx auto repeat-y; }
.category-tabs { display:flex; flex:0 0 76rpx; height:76rpx; padding:0 60rpx; border-bottom:1rpx solid rgba(214,202,185,.65); }
.category-tab { position:relative; flex:1; height:76rpx; color:#746b60; font-size:24rpx; line-height:76rpx; }
.category-tab--active { color:#a87025; }
.category-tab--active::after { position:absolute; right:50%; bottom:-1rpx; width:50rpx; height:3rpx; border-radius:2rpx; background:#bd883c; transform:translateX(50%); content:""; }
.meridian-search { display:flex; align-items:center; flex:0 0 62rpx; height:62rpx; margin:12rpx 30rpx; padding:0 20rpx; border:1rpx solid rgba(225,214,198,.8); border-radius:28rpx; background:rgba(255,253,248,.75); }
.meridian-search image { width:28rpx; height:28rpx; opacity:.62; }
.meridian-search input { flex:1; height:62rpx; margin-left:16rpx; color:#40372d; font-size:22rpx; }
.meridian-search button { color:#aa762f; font-size:19rpx; }
.search-placeholder { color:#a0968b; }
.content-scroll { flex:1; min-height:0; }
.overview-list { padding:0 0 20rpx; }
.meridian-card { margin-bottom:16rpx; border-bottom:1rpx solid rgba(225,214,198,.75); background:rgba(255,253,248,.45); }
.card-head { display:flex; align-items:flex-start; justify-content:space-between; padding:28rpx 34rpx 12rpx; }
.meridian-title { color:#30271e; font-family:"KaiTi","STKaiti",serif; font-size:31rpx; font-weight:700; }
.meridian-summary { margin-top:8rpx; color:#80766b; font-size:20rpx; line-height:1.5; }
.detail-button { flex:0 0 auto; margin-top:6rpx; padding:5rpx 17rpx; border:1rpx solid #c9964d; border-radius:20rpx; color:#a66e24; font-size:18rpx; line-height:29rpx; }
.diagram-stage { position:relative; height:480rpx; margin:0 24rpx 18rpx; overflow:hidden; border-radius:14rpx; background:rgba(249,241,230,.54); }
.diagram-image { display:block; width:100%; height:100%; filter:saturate(.55); }
.marker { position:absolute; display:flex; align-items:center; width:170rpx; height:28rpx; transform:translateY(-50%); }
.marker-dot { flex:0 0 9rpx; width:9rpx; height:9rpx; border:2rpx solid #fff8ec; border-radius:50%; background:#9e6a28; box-shadow:0 0 0 1rpx #9e6a28; }
.marker-line { flex:0 0 60rpx; width:60rpx; height:1rpx; background:#8d857b; }
.marker text { margin-left:8rpx; color:#453a2e; font-size:18rpx; white-space:nowrap; }
.simple-list { padding:18rpx 25rpx; }
.simple-card { position:relative; margin-bottom:15rpx; padding:25rpx 24rpx 52rpx; border:1rpx solid rgba(229,218,202,.8); border-radius:13rpx; background:rgba(255,253,248,.78); }
.simple-title { color:#30271e; font-size:28rpx; font-weight:600; }
.simple-copy { margin-top:14rpx; color:#6d6255; font-size:22rpx; line-height:1.65; }
.simple-action { position:absolute; right:20rpx; bottom:16rpx; color:#a66e24; font-size:19rpx; }
.acupoint-grid { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:15rpx; padding:20rpx 25rpx; }
.acupoint-card { padding:27rpx 20rpx; border:1rpx solid rgba(229,218,202,.8); border-radius:13rpx; background:rgba(255,253,248,.78); }
.acupoint-name { color:#30271e; font-family:"KaiTi","STKaiti",serif; font-size:29rpx; font-weight:600; }
.acupoint-source { margin-top:11rpx; color:#a27537; font-size:19rpx; }
.empty-state { padding:160rpx 20rpx; color:#9a8f83; font-size:23rpx; text-align:center; }
.bottom-spacer { height:calc(125rpx + env(safe-area-inset-bottom)); }
